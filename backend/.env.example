# Puerto del servidor
PORT=3001

# Entorno (development/production)
NODE_ENV=development

# URL de la API (backend)
API_URL=http://localhost:3001

# Base de datos PostgreSQL (Supabase)
DATABASE_URL=postgresql://usuario:contraseña@host:5432/nombre_bd

# JWT
JWT_SECRET=genera_un_secreto_con_openssl_rand_hex_64
JWT_EXPIRES_IN=7d

# Proveedor de almacenamiento (supabase/cloudinary)
STORAGE_PROVIDER=supabase

# Supabase
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_SERVICE_KEY=tu_service_role_key

# SMTP (Gmail u otro)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu-correo@gmail.com
SMTP_PASS=tu_app_password

# Email de destino para formulario de contacto
EMAIL_DESTINO=tu-correo@gmail.com

# URL del frontend (para enlaces en emails)
FRONTEND_URL=http://localhost:5173

# URL del logo para emails (por defecto: imagen pública placeholder)
# En producción, poner la URL real del logo alojado en tu servidor:
# APP_LOGO_URL=https://tudominio.com/img/logo.png
APP_LOGO_URL=

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_MONTHLY_PRICE_ID_5=price_...
STRIPE_MONTHLY_PRICE_ID_10=price_...
